# Основные переменные
NODE_ENV=development
PORT=4000

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_name

# JWT (если используешь аутентификацию)
JWT_SECRET=secret
JWT_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Логирование
LOG_LEVEL=debug

# API
API_VERSION=v1

# Telegram Bot (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=QuickResponseBot